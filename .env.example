# ─────────────────────────────────────────────────────────────
# THE MAHIR TECH — Environment variables
# Copy to .env.local for local dev. In Coolify, add these in the
# service's Environment Variables panel.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for canonical URLs, sitemap, OG). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://themahirtech.com

# ── Lead form email (Resend) ──────────────────────────────────
# Get an API key at https://resend.com. Without it, leads are logged
# to the server console (the form still works and shows success).
RESEND_API_KEY=
# Where inquiries are delivered:
LEAD_TO_EMAIL=m.sohail7797@gmail.com
# Verified sender (must be a domain verified in Resend):
LEAD_FROM_EMAIL=leads@themahirtech.com

# ── Sanity CMS (optional) ─────────────────────────────────────
# Leave blank to run on built-in seed content. Set these to enable
# the CMS and the /studio editor. Create a project at https://sanity.io.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
